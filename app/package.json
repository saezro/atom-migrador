{
  "name": "atom-migrador",
  "version": "1.0.0",
  "description": "Migrador Dropbox → Google Shared Drive | Aerotools-UAV",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "predist": "node scripts/download-rclone.mjs",
    "dist": "npm run build && electron-builder --win --publish never",
    "dist:gh": "npm run build && electron-builder --win --publish always"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.aerotools.atom-migrador",
    "productName": "Atom Migrador",
    "directories": { "output": "dist" },
    "files": ["out/**/*"],
    "extraResources": [
      { "from": "resources/extra", "to": "extra", "filter": ["**/*"] }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "Aerotools-UAV",
      "repo": "atom-migrador"
    }
  }
}
