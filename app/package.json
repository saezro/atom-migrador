{
  "name": "atom-migrador",
  "version": "1.0.18",
  "description": "Migrador Dropbox → Google Shared Drive | Aerotools-UAV",
  "author": {
    "name": "Aerotools-UAV",
    "email": "info@aerotools-uav.com",
    "url": "https://aerotools-uav.com"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "predist": "node scripts/download-rclone.mjs",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --publish never",
    "postdist": "node scripts/copy-installer.mjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "cross-env": "^10.1.0",
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.aerotools.atom-migrador",
    "productName": "Atom Migrador",
    "copyright": "Copyright © 2025 Aerotools-UAV",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/extra",
        "to": "extra",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Atom-Migrador-Setup-${version}.${ext}",
      "icon": "resources/icon.ico",
      "signingHashAlgorithms": [],
      "sign": null
    },
    "compression": "store",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "saezro",
      "repo": "atom-migrador"
    }
  }
}
